<!DOCTYPE html>
<html>
<head>
    <title>Catalogue</title>
</head>
<body>
<center>
    <h2>Book Catalogue</h2>
    <table border="1" cellpadding="10" cellspacing="0">
        <tr>
            <th>Book</th>
            <th>Book Name</th>
            <th>Price</th>
            <th>Action</th>
        </tr
        <tr>
            <td>
                <img src="https://m.media-amazon.com/images/I/81BE7eeKzAL.jpg"
                     width="100" height="140" alt="Java Book">
            </td>
            <td>Head First Java</td>
            <td>₹650</td>
            <td>
                <input type="button" value="Add to Cart">
            </td>
        </tr>
        <tr>
            <td>
                <img src="https://m.media-amazon.com/images/I/71g2ednj0JL.jpg"
                     width="100" height="140" alt="C Programming">
            </td>
            <td>The C Programming Language</td>
            <td>₹550</td>
            <td>
                <input type="button" value="Add to Cart">
            </td>
        </tr>
        <tr>
            <td>
                <img src="https://m.media-amazon.com/images/I/81iqZ2HHD-L.jpg"
                     width="100" height="140" alt="Python Book">
            </td>
            <td>Python Crash Course</td>
            <td>₹720</td>
            <td>
                <input type="button" value="Add to Cart">
            </td>
        </tr>
        <tr>
            <td>
                <img src="https://m.media-amazon.com/images/I/91asIC1fRwL.jpg"
                     width="100" height="140" alt="DBMS Book">
            </td>
            <td>Database System Concepts</td>
            <td>₹890</td>
            <td>
                <input type="button" value="Add to Cart">
            </td>
        </tr>
    </table>
</center>
</body>
</html>